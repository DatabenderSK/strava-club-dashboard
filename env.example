# === REQUIRED: Strava API credentials ===
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token

# Your Strava club ID (find it in the club URL: strava.com/clubs/YOUR_ID)
STRAVA_CLUB_ID=123456

# === OPTIONAL: Customize your dashboard ===
# Club display name (shown in header and title)
CLUB_NAME=My Cycling Club

# Weather location (latitude, longitude) — uses Open-Meteo, no API key needed
# Default: New York City. Find yours at https://www.latlong.net/
WEATHER_LAT=40.71
WEATHER_LON=-74.01

# Timezone for timestamps (list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/New_York
